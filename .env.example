SECRET_KEY=개발용이니-아무-값이나-넣어도-됩니다
DEBUG=True

# EC2 배포시: EC2 퍼블릭 IP 또는 도메인 입력 (쉼표로 구분)
# 예: ALLOWED_HOSTS=123.456.789.0,mydomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=household_db
POSTGRES_USER=household_user
POSTGRES_PASSWORD=household_password
DB_HOST=localhost
DB_PORT=5433

EMAIL_HOST_USER=이메일주소
EMAIL_HOST_PASSWORD=앱 비밀번호 16자리

# 로컬 개발용 Redis (docker-compose.dev.yml 사용 시)
CELERY_BROKER_URL=redis://localhost:6379/0

# -----------------------------------------------
# 프로덕션 전용 (EC2 서버의 .env에 반드시 설정)
# -----------------------------------------------

# Docker Hub 유저명 (docker-compose.prod.yml에서 이미지 이름에 사용)
DOCKER_USERNAME=도커허브유저명

# Django 설정 모듈 (프로덕션에서는 prod 사용)
DJANGO_SETTINGS_MODULE=config.setting.prod

# Redis (Docker Compose 내부 네트워크 사용 시 아래 값으로 덮어쓸 것)
# CELERY_BROKER_URL=redis://redis:6379/0
